{
  "name": "@cinatra-ai/video-artifact",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "artifact",
    "displayName": "Video",
    "vendor": {
      "key": "cinatra-ai",
      "name": "Cinatra"
    },
    "dependencies": [],
    "artifact": {
      "accepts": {
        "file": {
          "mimeTypes": [
            "video/mp4",
            "video/webm",
            "video/ogg"
          ]
        }
      },
      "ui": {
        "abiVersion": 1,
        "sdkAbiRange": "^2.4.0",
        "renderers": {
          "detail": {
            "entry": "./src/renderers/detail.tsx",
            "propsApiVersion": 1,
            "representations": [
              "video/*"
            ]
          }
        }
      }
    }
  }
}
